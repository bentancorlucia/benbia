---
import '@fontsource-variable/syne';
import '@fontsource-variable/outfit';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Benbia — Soluciones de Software',
  description = 'Desarrollo, diseño y consultoría tecnológica para empresas que piensan diferente.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#084c61" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Noise texture overlay -->
    <div class="noise-layer" aria-hidden="true">
      <svg class="noise-svg">
        <filter id="noiseFilter">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noiseFilter)" />
      </svg>
    </div>

    <!-- Aurora gradient background -->
    <div class="aurora" aria-hidden="true">
      <div class="aurora__blob aurora__blob--1"></div>
      <div class="aurora__blob aurora__blob--2"></div>
      <div class="aurora__blob aurora__blob--3"></div>
    </div>

    <!-- Scroll progress bar -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <slot />
  </body>
</html>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: var(--canary-yellow);
    z-index: 100;
    pointer-events: none;
    transform-origin: left;
    will-change: width;
  }

  .noise-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    opacity: 0.25;
    mix-blend-mode: overlay;
  }

  .noise-svg {
    width: 100%;
    height: 100%;
  }

  .aurora {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background-color: var(--dark-teal);
  }

  .aurora__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    mix-blend-mode: screen;
    will-change: transform;
  }

  .aurora__blob--1 {
    width: 55vw;
    height: 55vw;
    top: -10%;
    left: -10%;
    background: var(--berry-crush);
    opacity: 0.45;
    animation: drift 25s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
  }

  .aurora__blob--2 {
    width: 45vw;
    height: 45vw;
    top: 30%;
    right: -10%;
    background: var(--muted-teal);
    opacity: 0.4;
    animation: drift-reverse 30s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
    animation-delay: -5s;
  }

  .aurora__blob--3 {
    width: 65vw;
    height: 50vw;
    bottom: -15%;
    left: 20%;
    background: var(--canary-yellow);
    filter: blur(150px);
    opacity: 0.25;
    animation: drift 25s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
    animation-delay: -10s;
  }

  @media (max-width: 768px) {
    .aurora__blob {
      filter: blur(80px);
    }
    .aurora__blob--1 { width: 70vw; height: 70vw; }
    .aurora__blob--2 { width: 60vw; height: 60vw; }
    .aurora__blob--3 { width: 80vw; height: 60vw; }
  }

  @media (max-width: 480px) {
    .aurora__blob {
      filter: blur(60px);
      animation: none;
    }
    .aurora__blob--3 {
      display: none;
    }
  }
</style>
