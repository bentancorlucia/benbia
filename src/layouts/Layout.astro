---
import '@fontsource-variable/syne';
import '@fontsource-variable/outfit';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Benbia — Soluciones de Software',
  description = 'Desarrollo, diseño y consultoría tecnológica para empresas que piensan diferente.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#084c61" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Page-level gradient mesh background -->
    <div class="gradient-mesh" aria-hidden="true">
      <div class="gradient-mesh__layer gradient-mesh__layer--1"></div>
      <div class="gradient-mesh__layer gradient-mesh__layer--2"></div>
      <div class="gradient-mesh__layer gradient-mesh__layer--3"></div>
      <div class="gradient-mesh__layer gradient-mesh__layer--4"></div>
      <div class="gradient-mesh__noise"></div>
    </div>
    <slot />
  </body>
</html>

<style>
  .gradient-mesh {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background-color: var(--dark-teal);
  }

  .gradient-mesh__layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    will-change: transform;
  }

  /* Berry crush — top left */
  .gradient-mesh__layer--1 {
    width: 70vw;
    height: 70vh;
    top: -15%;
    left: -15%;
    background: radial-gradient(circle, var(--berry-crush) 0%, transparent 70%);
    opacity: 0.6;
    animation: mesh-drift-1 25s ease-in-out infinite;
  }

  /* Dark teal deep — top right */
  .gradient-mesh__layer--2 {
    width: 80vw;
    height: 80vh;
    top: -10%;
    right: -20%;
    background: radial-gradient(circle, var(--dark-teal-deep) 0%, transparent 70%);
    opacity: 0.85;
    animation: mesh-drift-2 30s ease-in-out infinite;
  }

  /* Canary yellow — bottom left */
  .gradient-mesh__layer--3 {
    width: 60vw;
    height: 60vh;
    bottom: -10%;
    left: -10%;
    background: radial-gradient(circle, var(--canary-yellow) 0%, transparent 70%);
    opacity: 0.25;
    animation: mesh-drift-3 20s ease-in-out infinite;
  }

  /* Muted teal — bottom right */
  .gradient-mesh__layer--4 {
    width: 65vw;
    height: 65vh;
    bottom: -20%;
    right: -10%;
    background: radial-gradient(circle, var(--muted-teal) 0%, transparent 70%);
    opacity: 0.35;
    animation: mesh-drift-4 28s ease-in-out infinite;
  }

  /* Grain texture */
  .gradient-mesh__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
  }

  @keyframes mesh-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(5%, 3%) scale(1.05); }
    66% { transform: translate(-3%, 5%) scale(0.98); }
  }

  @keyframes mesh-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-4%, 2%) scale(1.03); }
    66% { transform: translate(3%, -3%) scale(0.97); }
  }

  @keyframes mesh-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(3%, -4%) scale(1.06); }
    66% { transform: translate(-5%, 2%) scale(0.95); }
  }

  @keyframes mesh-drift-4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-3%, -3%) scale(1.04); }
    66% { transform: translate(4%, 4%) scale(0.96); }
  }
</style>
