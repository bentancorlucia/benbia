---
const services = [
  {
    num: '01',
    title: 'Desarrollo Web',
    desc: 'Plataformas web robustas, rápidas y escalables. Arquitectura de vanguardia diseñada para soportar alto tráfico.',
    tags: ['SaaS', 'E-commerce', 'Corporativo'],
    icon: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
    size: 'large',
  },
  {
    num: '02',
    title: 'Aplicaciones Móviles',
    desc: 'Apps nativas y multiplataforma con experiencias fluidas que conectan con tus usuarios.',
    tags: ['iOS', 'Android', 'Cross-platform'],
    icon: 'M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3',
    size: 'normal',
  },
  {
    num: '03',
    title: 'Consultoría Tecnológica',
    desc: 'Asesoría estratégica para elegir la tecnología correcta y escalar tu infraestructura.',
    tags: ['Arquitectura', 'DevOps', 'Estrategia'],
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
    size: 'normal',
  },
  {
    num: '04',
    title: 'Inteligencia de Datos',
    desc: 'Transformamos tus datos masivos en decisiones precisas en tiempo real.',
    tags: ['Dashboards', 'IA', 'Automatización'],
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
    size: 'wide',
  },
];
---

<section class="services section--railed" id="servicios">
  <div class="services__inner">
    <div class="services__header">
      <span class="label services__label">[ Área de expertise ]</span>
      <h2 class="services__title">
        <span class="services__title-line">Soluciones a</span>
        <span class="services__title-line"><em>medida.</em></span>
      </h2>
    </div>

    <div class="services__bento">
      {
        services.map((service, i) => (
          <article class={`services__card services__card--${service.size}`} data-service-index={i}>
            <div class="services__card-glow" aria-hidden="true" />
            <div class="services__card-top">
              <div class="services__card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                </svg>
              </div>
              <span class="services__card-num mono">{service.num}</span>
            </div>
            <div class="services__card-body">
              <h3 class="services__card-title">{service.title}</h3>
              <p class="services__card-desc">{service.desc}</p>
            </div>
            <div class="services__card-tags">
              {service.tags.map((tag) => (
                <span class="services__tag mono">{tag}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
    padding-block: var(--space-2xl);
    overflow: hidden;
  }

  .services__inner {
    padding-inline: var(--container-padding);
  }

  /* Header */
  .services__header {
    margin-bottom: clamp(3rem, 8vw, 6rem);
    max-width: 640px;
  }

  .services__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(12px);
  }

  .services__label::before {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--muted-teal);
  }

  .services__title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .services__title-line {
    display: block;
    opacity: 0;
    transform: translateY(20px);
    white-space: nowrap;
  }

  .services__title em {
    font-style: italic;
    color: var(--canary-yellow);
    font-weight: 400;
    font-family: 'Outfit Variable', sans-serif;
    font-size: inherit;
  }

  /* Bento Grid */
  .services__bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: auto;
    gap: 1.5rem;
  }

  /* Card Sizes */
  .services__card--large {
    grid-column: span 2;
    grid-row: span 2;
    min-height: 420px;
  }

  .services__card--normal {
    grid-column: span 1;
    grid-row: span 1;
  }

  .services__card--wide {
    grid-column: span 3;
  }

  .services__card--wide .services__card-body {
    max-width: 50%;
  }

  /* Card Base */
  .services__card {
    position: relative;
    background: var(--glass-white);
    border: 1px solid var(--glass-border);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 3rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transition: border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0;
    transform: translateY(30px);
  }

  .services__card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.5);
  }

  /* Hover glow overlay */
  .services__card-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(237, 240, 96, 0.06) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .services__card:hover .services__card-glow {
    opacity: 1;
  }

  /* Card Top */
  .services__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
    z-index: 1;
  }

  .services__card-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: rgba(8, 76, 97, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--canary-yellow);
    transition: border-color 0.5s ease;
  }

  .services__card--large .services__card-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
  }

  .services__card--large .services__card-icon svg {
    width: 28px;
    height: 28px;
  }

  .services__card:hover .services__card-icon {
    border-color: rgba(237, 240, 96, 0.3);
  }

  .services__card-num {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.2);
  }

  /* Card Body */
  .services__card-body {
    position: relative;
    z-index: 1;
    margin-bottom: clamp(1rem, 2vw, 2rem);
  }

  .services__card-title {
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--heading-light);
    letter-spacing: -0.01em;
    transition: color 0.4s ease;
  }

  .services__card--large .services__card-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 0.75rem;
  }

  .services__card-desc {
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.7;
    color: var(--muted-teal);
    font-weight: 350;
    max-width: 480px;
  }

  .services__card--large .services__card-desc {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
  }

  /* Tags */
  .services__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .services__tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(107, 171, 144, 0.3);
    color: var(--muted-teal);
    background: rgba(107, 171, 144, 0.05);
    white-space: nowrap;
    transition: border-color 0.4s ease, color 0.4s ease;
  }

  .services__card:hover .services__tag {
    border-color: var(--canary-yellow-50);
    color: var(--canary-yellow);
  }

  /* Responsive: Tablet */
  @media (max-width: 1024px) {
    .services__bento {
      grid-template-columns: repeat(2, 1fr);
    }

    .services__card--large {
      grid-column: span 2;
      grid-row: span 1;
      min-height: 320px;
    }

    .services__card--wide {
      grid-column: span 2;
    }

    .services__card--wide .services__card-body {
      max-width: 100%;
    }
  }

  /* Responsive: Mobile */
  @media (max-width: 768px) {
    .services {
      border: none;
    }

    .services__title {
      font-size: clamp(2.2rem, 8.5vw, 3.5rem);
    }

    .services__bento {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .services__card--large,
    .services__card--normal,
    .services__card--wide {
      grid-column: span 1;
      grid-row: span 1;
      min-height: auto;
    }

    .services__card--wide .services__card-body {
      max-width: 100%;
    }

    .services__card {
      border-radius: 1.25rem;
      padding: 1.5rem;
    }

    .services__card-icon {
      width: 2.75rem;
      height: 2.75rem;
    }

    .services__card--large .services__card-icon {
      width: 3rem;
      height: 3rem;
    }
  }

  @media (max-width: 480px) {
    .services__card-title {
      font-size: 1.2rem;
    }

    .services__card--large .services__card-title {
      font-size: 1.4rem;
    }

    .services__card-desc {
      font-size: 0.85rem;
      line-height: 1.6;
    }

    .services__tag {
      font-size: 0.55rem;
      padding: 0.25rem 0.6rem;
    }
  }
</style>
