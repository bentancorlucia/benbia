---
const projects = [
  {
    name: 'Atri',
    url: 'atri.com.uy',
    description: 'Plataforma corporativa con diseño moderno y experiencia de usuario optimizada.',
    tags: ['Web Corporativa', 'UI/UX', 'Responsive'],
    desktopImg: '/portfolio/atri-desktop.png',
    mobileImg: '/portfolio/atri-mobile.png',
  },
  {
    name: 'Proyecto 2',
    url: 'ejemplo2.com',
    description: 'E-commerce con catálogo dinámico y pasarela de pagos integrada.',
    tags: ['E-commerce', 'Pagos', 'Dashboard'],
    desktopImg: '/portfolio/proyecto2-desktop.png',
    mobileImg: '/portfolio/proyecto2-mobile.png',
  },
  {
    name: 'Proyecto 3',
    url: 'ejemplo3.com',
    description: 'Aplicación web progresiva con funcionalidades offline y notificaciones.',
    tags: ['PWA', 'Mobile First', 'API REST'],
    desktopImg: '/portfolio/proyecto3-desktop.png',
    mobileImg: '/portfolio/proyecto3-mobile.png',
  },
];
---

<section class="portfolio section" id="trabajos">
  <div class="container">
    <div class="portfolio__header reveal">
      <span class="label">Portfolio</span>
      <h2>Trabajos realizados</h2>
    </div>

    <div class="carousel" data-carousel>
      <div class="carousel__viewport">
        {projects.map((project, i) => (
          <div class={`carousel__slide ${i === 0 ? 'is-active' : ''}`} data-slide={i}>
            <div class="slide__inner">
              <div class="slide__mockups">
                <div class="mockup-desktop">
                  <div class="mockup-desktop__bar">
                    <span class="dot dot--red"></span>
                    <span class="dot dot--yellow"></span>
                    <span class="dot dot--green"></span>
                    <span class="mockup-desktop__url mono">{project.url}</span>
                  </div>
                  <div class="mockup-desktop__screen">
                    <img src={project.desktopImg} alt={`${project.name} desktop`} loading="lazy" />
                  </div>
                </div>
                <div class="mockup-mobile">
                  <div class="mockup-mobile__notch"></div>
                  <div class="mockup-mobile__screen">
                    <img src={project.mobileImg} alt={`${project.name} mobile`} loading="lazy" />
                  </div>
                </div>
              </div>
              <div class="slide__info">
                <h3>{project.name}</h3>
                <p>{project.description}</p>
                <div class="slide__tags">
                  {project.tags.map((tag) => (
                    <span class="slide__tag mono">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="carousel__nav">
        <button class="carousel__arrow" data-prev aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="carousel__indicators">
          {projects.map((_, i) => (
            <button class={`carousel__indicator ${i === 0 ? 'is-active' : ''}`} data-goto={i} aria-label={`Proyecto ${i + 1}`}></button>
          ))}
        </div>
        <button class="carousel__arrow" data-next aria-label="Siguiente">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  function initCarousel() {
    const carousel = document.querySelector('[data-carousel]');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('[data-slide]') as NodeListOf<HTMLElement>;
    const indicators = carousel.querySelectorAll('[data-goto]') as NodeListOf<HTMLElement>;
    const prevBtn = carousel.querySelector('[data-prev]') as HTMLElement;
    const nextBtn = carousel.querySelector('[data-next]') as HTMLElement;
    const total = slides.length;
    let current = 0;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      slides.forEach((s, idx) => s.classList.toggle('is-active', idx === current));
      indicators.forEach((d, idx) => d.classList.toggle('is-active', idx === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    indicators.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Swipe
    let x0: number | null = null;
    carousel.addEventListener('touchstart', (e: Event) => { x0 = (e as TouchEvent).touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', (e: Event) => {
      if (x0 === null) return;
      const dx = x0 - (e as TouchEvent).changedTouches[0].clientX;
      if (Math.abs(dx) > 50) goTo(current + (dx > 0 ? 1 : -1));
      x0 = null;
    });
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
  document.addEventListener('astro:page-load', initCarousel);
</script>

<style>
  .portfolio {
    background-color: var(--dark-teal);
    position: relative;
  }

  .portfolio::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--muted-teal-20), transparent);
  }

  .portfolio__header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .portfolio__header .label {
    display: block;
    margin-bottom: var(--space-sm);
  }

  .portfolio__header h2 {
    margin-bottom: 0;
  }

  /* ── Carousel ── */
  .carousel__viewport {
    position: relative;
    min-height: 420px;
  }

  .carousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px) scale(0.98);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel__slide.is-active {
    position: relative;
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .slide__inner {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: var(--space-lg);
    align-items: center;
  }

  /* ── Device Mockups ── */
  .slide__mockups {
    position: relative;
  }

  .mockup-desktop {
    background: #0b1e26;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 6px 30px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(107, 171, 144, 0.08);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
  }

  .slide__mockups:hover .mockup-desktop {
    transform: translateY(-4px);
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(107, 171, 144, 0.12);
  }

  .slide__mockups:hover .mockup-mobile {
    transform: translateY(-6px) translateX(-2px);
  }

  .mockup-desktop__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    background: #0e2a36;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #ffbd2e; }
  .dot--green { background: #28c840; }

  .mockup-desktop__url {
    margin-left: 8px;
    font-size: 0.6rem;
    color: var(--muted-teal);
    opacity: 0.5;
    background: rgba(107,171,144,0.08);
    padding: 3px 12px;
    border-radius: 4px;
  }

  .mockup-desktop__screen {
    aspect-ratio: 16 / 10;
    background: linear-gradient(135deg, #063040, #041e28);
    overflow: hidden;
  }

  .mockup-desktop__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .mockup-mobile {
    position: absolute;
    right: -20px;
    bottom: -24px;
    width: 22%;
    min-width: 90px;
    background: #0b1e26;
    border-radius: 18px;
    padding: 5px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.45), 0 0 0 1px rgba(107,171,144,0.1);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
  }

  .mockup-mobile__notch {
    width: 34%;
    height: 4px;
    background: #0e2a36;
    border-radius: 8px;
    margin: 5px auto 3px;
  }

  .mockup-mobile__screen {
    aspect-ratio: 9 / 16;
    border-radius: 13px;
    overflow: hidden;
    background: linear-gradient(135deg, #063040, #041e28);
  }

  .mockup-mobile__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  /* ── Info ── */
  .slide__info h3 {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    margin-bottom: 0.5rem;
  }

  .slide__info p {
    opacity: 0.85;
    line-height: 1.6;
    margin-bottom: 1rem;
    max-width: 380px;
  }

  .slide__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .slide__tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    border-radius: 100px;
    border: 1px solid var(--muted-teal-20);
    color: var(--canary-yellow);
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .slide__tag:hover {
    border-color: var(--canary-yellow-50);
    background-color: var(--canary-yellow-10);
  }

  /* ── Nav ── */
  .carousel__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: var(--space-lg);
  }

  .carousel__arrow {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--muted-teal-20);
    background: transparent;
    color: var(--muted-teal);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition:
      border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.4s ease;
  }

  .carousel__arrow:hover {
    border-color: var(--canary-yellow);
    color: var(--dark-teal);
    background-color: var(--canary-yellow);
    transform: scale(1.1);
  }

  .carousel__arrow:active {
    transform: scale(0.95);
    transition-duration: 0.1s;
  }

  .carousel__indicators {
    display: flex;
    gap: 8px;
  }

  .carousel__indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid var(--muted-teal-20);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition:
      all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel__indicator:hover {
    border-color: var(--canary-yellow-50);
    transform: scale(1.2);
  }

  .carousel__indicator.is-active {
    background: var(--canary-yellow);
    border-color: var(--canary-yellow);
    transform: scale(1.4);
    box-shadow: 0 0 12px rgba(237, 240, 96, 0.3);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .slide__inner {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .carousel__viewport {
      min-height: auto;
    }

    .mockup-mobile {
      right: -10px;
      bottom: -16px;
      width: 24%;
    }

    .slide__info p {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .mockup-desktop {
      border-radius: 8px;
    }

    .mockup-desktop__bar {
      padding: 7px 10px;
      gap: 5px;
    }

    .dot {
      width: 7px;
      height: 7px;
    }

    .mockup-desktop__url {
      font-size: 0.5rem;
    }

    .mockup-mobile {
      width: 26%;
      min-width: 70px;
      border-radius: 12px;
      padding: 3px;
      right: -6px;
      bottom: -12px;
    }

    .mockup-mobile__screen {
      border-radius: 10px;
    }

    .carousel__arrow {
      width: 36px;
      height: 36px;
    }

    .carousel__arrow svg {
      width: 14px;
      height: 14px;
    }
  }
</style>
