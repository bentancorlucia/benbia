---
const projects = [
  {
    name: 'ATRI',
    url: 'atri.com.uy',
    description: 'Sitio web institucional en Next.js 15, Tailwind y Framer Motion, con backend en Supabase. Incluye páginas públicas (home, socios, beneficios y eventos), un panel administrativo para gestionar contenidos y un sistema de micrositios por evento con bloques editables (hero, costos, agenda). Diseño propio con paleta naranja/celeste, tipografías Unbounded y Geist, animaciones sutiles y enfoque mobile-first.',
    tags: ['Next.js 15', 'Tailwind', 'Framer Motion', 'Supabase', 'Mobile-first'],
    desktopImg: '/portfolio/atri-desktop.png',
  },
  {
    name: 'Nido',
    url: 'App de Escritorio',
    description: 'Aplicación de escritorio multiplataforma para organización personal y académica. Integra gestión de tareas con drag & drop, calendario multi-vista con sincronización de Google Calendar, proyectos jerárquicos, pomodoro timer y un dashboard con widgets personalizables.',
    tags: ['Electron', 'React', 'TypeScript', 'SQLite', 'Offline-first'],
    desktopImg: '/portfolio/nido-desktop.png',
    icon: '/portfolio/nido-icon.png',
  },
  {
    name: 'Admin-Edificios',
    url: 'App de Escritorio',
    description: 'Aplicación de escritorio multiplataforma para administradores de edificios. Centraliza apartamentos, propietarios, inquilinos, gastos comunes, cuentas bancarias y reportes PDF — con almacenamiento local sin dependencia de la nube.',
    tags: ['Desktop App', 'Administración', 'Finanzas', 'Reportes'],
    desktopImg: '/portfolio/admin-edificios-desktop.png',
    icon: '/portfolio/admin-edificios-icon.png',
  },
];
---

<section class="portfolio" id="trabajos">
  <!-- Ambient glow -->
  <div class="portfolio__glow portfolio__glow--1"></div>
  <div class="portfolio__glow portfolio__glow--2"></div>

  <div class="portfolio__header">
    <div class="portfolio__header-left">
      <div class="portfolio__label-row">
        <span class="label">[ Portfolio ]</span>
        <div class="portfolio__label-line"></div>
      </div>
      <h2>Trabajos<br><span class="portfolio__heading-muted">realizados</span></h2>
    </div>
    <div class="portfolio__nav" data-carousel-nav>
      <button class="portfolio__arrow" data-prev aria-label="Anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="portfolio__arrow" data-next aria-label="Siguiente">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <div class="portfolio__track" data-carousel>
    {projects.map((project, i) => (
      <div class="portfolio__slide reveal" data-slide={i}>
        <div class="portfolio__card glass-card">
          <!-- Desktop mockup -->
          <div class="portfolio__mockup">
            <div class="portfolio__mockup-container">
              <div class="mockup-desktop">
                <div class="mockup-desktop__bar">
                  <span class="dot dot--red"></span>
                  <span class="dot dot--yellow"></span>
                  <span class="dot dot--green"></span>
                  <span class="mockup-desktop__url mono">{project.url}</span>
                </div>
                <div class="mockup-desktop__screen">
                  <img src={project.desktopImg} alt={`${project.name} desktop`} loading="lazy" />
                  <div class="mockup-desktop__fade"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Info -->
          <div class="portfolio__info">
            <div class="portfolio__info-inner">
              <div class="portfolio__info-glow"></div>
              <div class="portfolio__info-top">
                {project.icon && (
                  <img src={project.icon} alt={`${project.name} icon`} class="portfolio__icon" loading="lazy" />
                )}
                <div class="portfolio__info-title">
                  <h3>{project.name}</h3>
                  <span class="portfolio__subtitle mono">{project.url}</span>
                </div>
              </div>
              <p>{project.description}</p>
              <div class="portfolio__tags">
                {project.tags.map((tag, ti) => (
                  <span class="portfolio__tag mono">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Dots -->
  <div class="portfolio__dots">
    {projects.map((_, i) => (
      <button
        class={`portfolio__dot ${i === 0 ? 'is-active' : ''}`}
        data-goto={i}
        aria-label={`Proyecto ${i + 1}`}
      />
    ))}
  </div>
</section>

<script>
  function initCarousel() {
    const track = document.querySelector('[data-carousel]') as HTMLElement;
    if (!track) return;

    const slides = track.querySelectorAll('[data-slide]') as NodeListOf<HTMLElement>;
    const dots = document.querySelectorAll('[data-goto]') as NodeListOf<HTMLElement>;
    const prevBtn = document.querySelector('[data-prev]') as HTMLElement;
    const nextBtn = document.querySelector('[data-next]') as HTMLElement;
    const total = slides.length;
    let current = 0;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      const slide = slides[current];
      if (slide) {
        slide.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
      dots.forEach((d, idx) => d.classList.toggle('is-active', idx === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Update dots on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const idx = Number((entry.target as HTMLElement).dataset.slide);
          current = idx;
          dots.forEach((d, di) => d.classList.toggle('is-active', di === idx));
        }
      });
    }, { root: track, threshold: 0.6 });

    slides.forEach((s) => observer.observe(s));

    // Swipe
    let x0: number | null = null;
    track.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      if (x0 === null) return;
      const dx = x0 - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 50) goTo(current + (dx > 0 ? 1 : -1));
      x0 = null;
    });
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
  document.addEventListener('astro:page-load', initCarousel);
</script>

<style>
  .portfolio {
    position: relative;
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(2px);
    overflow-x: clip;
    overflow-y: visible;
  }

  /* Ambient glows */
  .portfolio__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(120px);
  }

  .portfolio__glow--1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(170, 68, 101, 0.25) 0%, transparent 70%);
    top: -15%;
    right: -5%;
  }

  .portfolio__glow--2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(237, 240, 96, 0.1) 0%, transparent 70%);
    bottom: -10%;
    left: 5%;
  }

  .portfolio__header {
    position: relative;
    z-index: 2;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-lg);
  }

  .portfolio__label-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: var(--space-sm);
  }

  .portfolio__label-row .label {
    color: var(--canary-yellow);
    flex-shrink: 0;
  }

  .portfolio__label-line {
    height: 1px;
    flex-grow: 1;
    background: linear-gradient(to right, rgba(237, 240, 96, 0.3), transparent);
  }

  .portfolio__header-left h2 {
    margin-bottom: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .portfolio__heading-muted {
    color: var(--muted-teal);
  }

  .portfolio__heading-dot {
    color: var(--berry-crush);
  }

  .portfolio__nav {
    display: flex;
    gap: 0.75rem;
  }

  .portfolio__arrow {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: var(--heading-light);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .portfolio__arrow:hover {
    background: var(--heading-light);
    color: var(--dark-teal);
    transform: scale(1.05);
    border-color: transparent;
  }

  .portfolio__arrow:active {
    transform: scale(0.95);
    transition-duration: 0.1s;
  }

  /* Horizontal scroll track */
  .portfolio__track {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-inline: max(var(--container-padding), calc((100vw - var(--container-max)) / 2 + var(--container-padding)));
    padding-bottom: 6rem;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .portfolio__track::-webkit-scrollbar {
    display: none;
  }

  .portfolio__slide {
    scroll-snap-align: center;
    flex-shrink: 0;
    width: min(85vw, 960px);
  }

  .portfolio__card {
    padding: 0;
    height: 100%;
    display: flex;
    flex-direction: row;
    border-radius: 24px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 30px 60px -15px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: box-shadow 0.6s ease;
  }

  .portfolio__card:hover {
    box-shadow:
      0 40px 80px -20px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* Desktop mockup — hero element */
  .portfolio__mockup {
    flex: 1.2;
    position: relative;
    background: rgba(0, 0, 0, 0.3);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    overflow: hidden;
  }

  .portfolio__mockup-container {
    perspective: 2000px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    height: 100%;
    display: flex;
    align-items: center;
  }

  .mockup-desktop {
    background: #0a0a0a;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 40px 80px -20px rgba(0, 0, 0, 0.6),
      0 0 40px rgba(170, 68, 101, 0.1);
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.7s ease;
    transform-style: preserve-3d;
    width: 100%;
  }

  .portfolio__mockup-container:hover .mockup-desktop {
    transform: rotateY(-3deg) rotateX(1.5deg) translateY(-8px);
    box-shadow:
      0 50px 100px -20px rgba(0, 0, 0, 0.7),
      0 0 50px rgba(237, 240, 96, 0.08);
  }

  .mockup-desktop__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 16px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    opacity: 0.75;
  }
  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #ffbd2e; }
  .dot--green { background: #28c840; }

  .mockup-desktop__url {
    margin-left: 8px;
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.03);
    padding: 3px 12px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .mockup-desktop__screen {
    position: relative;
    aspect-ratio: 16 / 10;
    background: rgba(6, 48, 64, 0.5);
    overflow: hidden;
  }

  .mockup-desktop__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    opacity: 0.9;
    transition: opacity 0.5s ease, transform 0.7s ease;
  }

  .portfolio__card:hover .mockup-desktop__screen img {
    opacity: 1;
    transform: scale(1.02);
  }

  .mockup-desktop__fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40px;
    background: linear-gradient(to top, #0a0a0a, transparent);
    opacity: 0.5;
    pointer-events: none;
  }

  /* Info panel */
  .portfolio__info {
    flex: 0.8;
    display: flex;
    align-items: center;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .portfolio__info-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
  }

  .portfolio__info-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 150px;
    height: 150px;
    background: rgba(237, 240, 96, 0.06);
    filter: blur(60px);
    border-radius: 50%;
    pointer-events: none;
  }

  .portfolio__info-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .portfolio__icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    object-fit: cover;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .portfolio__info-title {
    display: flex;
    flex-direction: column;
  }

  .portfolio__info h3 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .portfolio__subtitle {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--berry-crush);
    margin-top: 0.25rem;
  }

  .portfolio__info p {
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    margin-top: 1rem;
    font-weight: 350;
    font-size: 0.95rem;
  }

  .portfolio__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .portfolio__tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 14px;
    border-radius: 2px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.6);
    transition: border-color 0.4s ease, background 0.4s ease;
  }

.portfolio__tag:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Dots */
  .portfolio__dots {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-md);
  }

  .portfolio__dot {
    width: 8px;
    height: 6px;
    border-radius: 3px;
    border: none;
    background: rgba(255, 255, 255, 0.15);
    cursor: pointer;
    padding: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .portfolio__dot:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: scaleY(1.2);
  }

  .portfolio__dot.is-active {
    width: 28px;
    background: var(--canary-yellow);
    box-shadow: 0 0 12px rgba(237, 240, 96, 0.3);
  }

  /* ========================= */
  /* Responsive — Tablet       */
  /* ========================= */
  @media (max-width: 900px) {
    .portfolio__card {
      flex-direction: column;
    }

    .portfolio__mockup {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .portfolio__slide {
      width: 88vw;
    }

    .portfolio__info {
      padding: 1.5rem;
    }
  }

  /* ========================= */
  /* Responsive — Mobile       */
  /* ========================= */
  @media (max-width: 768px) {
    .portfolio {
      padding-block: var(--space-xl);
    }

    .portfolio__header-left h2 {
      font-size: clamp(2.2rem, 8.5vw, 3.5rem);
    }

    .portfolio__glow--1 {
      width: 300px;
      height: 300px;
      right: -80px;
    }

    .portfolio__glow--2 {
      width: 250px;
      height: 250px;
    }

    .portfolio__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .portfolio__label-line {
      display: none;
    }

    .portfolio__slide {
      width: 88vw;
    }

    .portfolio__card {
      flex-direction: column;
      border-radius: 20px;
    }

    .portfolio__mockup {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .portfolio__mockup-container {
      padding: 1.25rem;
    }

    .portfolio__mockup-container:hover .mockup-desktop {
      transform: none;
    }

    .mockup-desktop {
      border-radius: 10px;
    }

    .portfolio__info {
      padding: 1.5rem;
    }

    .portfolio__info h3 {
      font-size: 1.6rem;
    }

    .portfolio__info p {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .portfolio__icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
    }

    .portfolio__arrow {
      width: 44px;
      height: 44px;
    }
  }

  @media (max-width: 480px) {
    .portfolio__card {
      border-radius: 16px;
    }

    .portfolio__mockup-container {
      padding: 1rem;
    }

    .mockup-desktop {
      border-radius: 8px;
    }

    .mockup-desktop__bar {
      padding: 7px 10px;
      gap: 5px;
    }

    .dot {
      width: 6px;
      height: 6px;
    }

    .mockup-desktop__url {
      font-size: 0.5rem;
    }

    .portfolio__info {
      padding: 1.25rem;
    }

    .portfolio__icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
    }

    .portfolio__info h3 {
      font-size: 1.4rem;
    }

    .portfolio__info p {
      font-size: 0.85rem;
      line-height: 1.5;
    }

    .portfolio__tag {
      font-size: 0.55rem;
      padding: 4px 10px;
    }

    .portfolio__arrow {
      width: 40px;
      height: 40px;
    }

    .portfolio__arrow svg {
      width: 14px;
      height: 14px;
    }
  }
</style>
