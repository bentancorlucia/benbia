---
const projects = [
  {
    name: 'Nido',
    url: 'App de Escritorio',
    description: 'Aplicación de escritorio multiplataforma para organización personal y académica. Integra gestión de tareas con drag & drop, calendario multi-vista con sincronización de Google Calendar, proyectos jerárquicos, pomodoro timer y un dashboard con widgets personalizables.',
    tags: ['Electron', 'React', 'TypeScript', 'SQLite', 'Offline-first'],
    desktopImg: '/portfolio/nido-desktop.png',
    icon: '/portfolio/nido-icon.png',
  },
  {
    name: 'Admin-Edificios',
    url: 'App de Escritorio',
    description: 'Aplicación de escritorio multiplataforma para administradores de edificios. Centraliza apartamentos, propietarios, inquilinos, gastos comunes, cuentas bancarias y reportes PDF — con almacenamiento local sin dependencia de la nube.',
    tags: ['Desktop App', 'Administración', 'Finanzas', 'Reportes'],
    desktopImg: '/portfolio/admin-edificios-desktop.png',
    icon: '/portfolio/admin-edificios-icon.png',
  },
];
---

<section class="portfolio section" id="trabajos">
  <div class="container">
    <div class="portfolio__header reveal">
      <span class="label">Portfolio</span>
      <h2>Trabajos realizados</h2>
    </div>

    <div class="carousel" data-carousel>
      <div class="carousel__viewport">
        {projects.map((project, i) => (
          <div class={`carousel__slide ${i === 0 ? 'is-active' : ''}`} data-slide={i}>
            <div class="slide__inner">
              <div class="slide__mockups">
                <div class="mockup-desktop">
                  <div class="mockup-desktop__bar">
                    <span class="dot dot--red"></span>
                    <span class="dot dot--yellow"></span>
                    <span class="dot dot--green"></span>
                    <span class="mockup-desktop__url mono">{project.url}</span>
                  </div>
                  <div class="mockup-desktop__screen">
                    <img src={project.desktopImg} alt={`${project.name} desktop`} loading="lazy" />
                  </div>
                </div>
                {project.icon && (
                  <div class="mockup-icon">
                    <img src={project.icon} alt={`${project.name} icon`} loading="lazy" />
                  </div>
                )}
              </div>
              <div class="slide__info">
                <h3>{project.name}</h3>
                <p>{project.description}</p>
                <div class="slide__tags">
                  {project.tags.map((tag) => (
                    <span class="slide__tag mono">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="carousel__nav">
        <button class="carousel__arrow" data-prev aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="carousel__indicators">
          {projects.map((_, i) => (
            <button class={`carousel__indicator ${i === 0 ? 'is-active' : ''}`} data-goto={i} aria-label={`Proyecto ${i + 1}`}></button>
          ))}
        </div>
        <button class="carousel__arrow" data-next aria-label="Siguiente">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  function initCarousel() {
    const carousel = document.querySelector('[data-carousel]');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('[data-slide]') as NodeListOf<HTMLElement>;
    const indicators = carousel.querySelectorAll('[data-goto]') as NodeListOf<HTMLElement>;
    const prevBtn = carousel.querySelector('[data-prev]') as HTMLElement;
    const nextBtn = carousel.querySelector('[data-next]') as HTMLElement;
    const total = slides.length;
    let current = 0;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      slides.forEach((s, idx) => s.classList.toggle('is-active', idx === current));
      indicators.forEach((d, idx) => d.classList.toggle('is-active', idx === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    indicators.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Swipe
    let x0: number | null = null;
    carousel.addEventListener('touchstart', (e: Event) => { x0 = (e as TouchEvent).touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', (e: Event) => {
      if (x0 === null) return;
      const dx = x0 - (e as TouchEvent).changedTouches[0].clientX;
      if (Math.abs(dx) > 50) goTo(current + (dx > 0 ? 1 : -1));
      x0 = null;
    });
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
  document.addEventListener('astro:page-load', initCarousel);
</script>

<style>
  .portfolio {
    position: relative;
  }

  .portfolio::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--glass-border), transparent);
  }

  .portfolio__header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .portfolio__header .label {
    display: block;
    margin-bottom: var(--space-sm);
  }

  .portfolio__header h2 {
    margin-bottom: 0;
  }

  /* Carousel */
  .carousel__viewport {
    position: relative;
    min-height: 420px;
  }

  .carousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px) scale(0.98);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel__slide.is-active {
    position: relative;
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .slide__inner {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: var(--space-lg);
    align-items: center;
  }

  /* Device Mockups */
  .slide__mockups {
    position: relative;
  }

  .mockup-desktop {
    background: rgba(11, 30, 38, 0.8);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: 0 6px 30px rgba(0, 0, 0, 0.25);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
  }

  .slide__mockups:hover .mockup-desktop {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .mockup-desktop__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    background: rgba(14, 42, 54, 0.6);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    opacity: 0.7;
  }
  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #ffbd2e; }
  .dot--green { background: #28c840; }

  .mockup-desktop__url {
    margin-left: 8px;
    font-size: 0.6rem;
    color: var(--muted-teal);
    opacity: 0.4;
    background: rgba(107, 171, 144, 0.06);
    padding: 3px 12px;
    border-radius: 4px;
  }

  .mockup-desktop__screen {
    aspect-ratio: 16 / 10;
    background: rgba(6, 48, 64, 0.5);
    overflow: hidden;
  }

  .mockup-desktop__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  /* App Icon */
  .mockup-icon {
    position: absolute;
    right: -20px;
    bottom: -24px;
    width: 22%;
    min-width: 90px;
    max-width: 120px;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mockup-icon img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .slide__mockups:hover .mockup-icon {
    transform: translateY(-4px);
  }

  /* Info */
  .slide__info h3 {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    margin-bottom: 0.5rem;
  }

  .slide__info p {
    opacity: 0.75;
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 380px;
    font-weight: 350;
  }

  .slide__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .slide__tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    border-radius: 100px;
    border: 1px solid var(--glass-border);
    color: var(--muted-teal);
    transition:
      border-color 0.4s ease,
      background-color 0.4s ease;
  }

  .slide__tag:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background-color: var(--glass-white);
  }

  /* Nav */
  .carousel__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: var(--space-lg);
  }

  .carousel__arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: var(--glass-white);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--muted-teal);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition:
      border-color 0.4s ease,
      color 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.4s ease;
  }

  .carousel__arrow:hover {
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--heading-light);
    background: var(--glass-white-10);
    transform: scale(1.08);
  }

  .carousel__arrow:active {
    transform: scale(0.95);
    transition-duration: 0.1s;
  }

  .carousel__indicators {
    display: flex;
    gap: 8px;
  }

  .carousel__indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel__indicator:hover {
    border-color: rgba(255, 255, 255, 0.2);
    transform: scale(1.2);
  }

  .carousel__indicator.is-active {
    background: var(--muted-teal);
    border-color: var(--muted-teal);
    transform: scale(1.3);
    box-shadow: 0 0 12px rgba(107, 171, 144, 0.25);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .slide__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .carousel__viewport {
      min-height: auto;
    }

    .mockup-icon {
      right: 8px;
      bottom: -12px;
      min-width: 60px;
      max-width: 80px;
    }

    .slide__info p {
      max-width: 100%;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .slide__tags {
      gap: 0.4rem;
    }
  }

  @media (max-width: 480px) {
    .mockup-desktop {
      border-radius: 8px;
    }

    .mockup-desktop__bar {
      padding: 7px 10px;
      gap: 5px;
    }

    .dot {
      width: 6px;
      height: 6px;
    }

    .mockup-desktop__url {
      font-size: 0.5rem;
    }

    .mockup-icon {
      right: 4px;
      bottom: -8px;
      min-width: 50px;
      max-width: 65px;
      border-radius: 12px;
    }

    .slide__info h3 {
      font-size: 1.2rem;
    }

    .slide__info p {
      font-size: 0.85rem;
      line-height: 1.5;
    }

    .slide__tag {
      font-size: 0.55rem;
      padding: 3px 8px;
    }

    .carousel__nav {
      margin-top: 1.5rem;
    }

    .carousel__arrow {
      width: 36px;
      height: 36px;
    }

    .carousel__arrow svg {
      width: 14px;
      height: 14px;
    }
  }

  @media (max-width: 360px) {
    .mockup-icon {
      display: none;
    }
  }
</style>
