<section class="contact section" id="contacto">
  <div class="container">
    <div class="contact__grid">
      <div class="contact__content reveal">
        <span class="label">Contacto</span>
        <h2>¿Tienes un proyecto<br />en mente?</h2>
        <p>
          Cuéntanos tu idea y diseñamos juntos la solución perfecta.
        </p>
        <a href="mailto:hola@benbia.dev" class="btn-primary contact__cta">
          Contactate
          <span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    overflow: hidden;
  }

  /* Warm gradient overlay */
  .contact::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(170, 68, 101, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact__grid {
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .contact__content {
    text-align: center;
    max-width: 560px;
    padding: var(--space-xl) var(--space-lg);
    background: var(--glass-white);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
  }

  .contact__content h2 {
    margin-bottom: var(--space-md);
    color: var(--heading-light);
  }

  .contact__content .label {
    display: block;
    margin-bottom: var(--space-sm);
    opacity: 0.6;
  }

  .contact__content p {
    color: var(--muted-teal);
    margin-bottom: var(--space-lg);
    font-weight: 350;
  }

  .contact__cta {
    display: inline-flex;
    text-decoration: none;
  }

  @media (max-width: 480px) {
    .contact__content {
      padding: var(--space-lg) var(--space-md);
    }

    .contact__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
