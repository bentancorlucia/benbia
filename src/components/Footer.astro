---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="#" class="footer__logo" aria-label="Benbia - Inicio">BENB<span class="logo-highlight">IA</span></a>
        <p class="footer__tagline mono">Pensado. Creado. Tuyo.</p>
      </div>

      <div class="footer__links">
        <a href="#servicios" class="footer__link">Servicios</a>
        <a href="#proceso" class="footer__link">Proceso</a>
        <a href="#trabajos" class="footer__link">Portfolio</a>
      </div>
    </div>

    <div class="footer__bottom">
      <span class="footer__copy mono">&copy; {year} Benbia. Todos los derechos reservados.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding-block: var(--space-xl) var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__logo {
    font-family: 'Syne Variable', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--heading-light);
    letter-spacing: -0.03em;
    transition: opacity 0.4s ease;
    line-height: 1;
  }

  .footer__logo :global(.logo-highlight) {
    color: var(--canary-yellow);
  }

  .footer__logo:hover {
    opacity: 0.7;
  }

  .footer__tagline {
    font-size: 0.75rem;
    color: var(--muted-teal);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .footer__links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__link {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
    transition:
      color 0.4s ease;
  }

  .footer__link:hover {
    color: var(--heading-light);
  }

  .footer__bottom {
    padding-top: var(--space-md);
    border-top: 1px solid var(--glass-border);
  }

  .footer__copy {
    font-size: 0.6rem;
    color: var(--muted-teal);
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .footer__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }

    .footer__logo {
      font-size: clamp(2.5rem, 10vw, 4rem);
    }
  }

  @media (max-width: 480px) {
    .footer {
      padding-block: var(--space-lg) var(--space-sm);
    }

    .footer__links {
      flex-direction: column;
      gap: 0.75rem;
    }

    .footer__link {
      font-size: 1rem;
      padding: 0.5rem 0;
    }

    .footer__copy {
      font-size: 0.55rem;
    }
  }
</style>
