---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="#" class="footer__logo" aria-label="Benbia - Inicio">BENBIA</a>
      <p class="footer__tagline">Pensado. Creado. Tuyo.</p>
    </div>

    <div class="footer__links">
      <a href="#servicios" class="nav-link">Servicios</a>
      <a href="#proceso" class="nav-link">Proceso</a>
      <a href="#nosotros" class="nav-link">Nosotros</a>
      <a href="#contacto" class="nav-link">Contacto</a>
    </div>

    <div class="footer__bottom">
      <span class="footer__copy mono">&copy; {year} Benbia. Todos los derechos reservados.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding-block: var(--space-lg) var(--space-md);
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-border),
      transparent
    );
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer__brand {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .footer__logo {
    font-family: 'Syne Variable', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--heading-light);
    letter-spacing: 0.08em;
    transition: opacity 0.4s ease;
  }

  .footer__logo:hover {
    opacity: 0.7;
  }

  .footer__tagline {
    font-size: 0.85rem;
    color: var(--muted-teal);
    opacity: 0.4;
    font-weight: 300;
  }

  .footer__links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__links .nav-link {
    font-size: 0.85rem;
    color: var(--muted-teal);
    opacity: 0.5;
    transition:
      opacity 0.4s ease,
      color 0.4s ease;
  }

  .footer__links .nav-link:hover {
    opacity: 1;
    color: var(--heading-light);
  }

  .footer__bottom {
    padding-top: var(--space-md);
    border-top: 1px solid var(--glass-border);
  }

  .footer__copy {
    font-size: 0.65rem;
    color: var(--muted-teal);
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .footer__brand {
      flex-direction: column;
      gap: 0.5rem;
    }

    .footer__links {
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .footer {
      padding-block: var(--space-md) var(--space-sm);
    }

    .footer__links {
      flex-direction: column;
      gap: 0.75rem;
    }

    .footer__links .nav-link {
      font-size: 0.9rem;
      padding: 0.25rem 0;
    }

    .footer__copy {
      font-size: 0.6rem;
    }
  }
</style>
