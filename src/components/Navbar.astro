---
---

<nav class="navbar" id="navbar">
  <div class="navbar__inner">
    <div class="navbar__brand">
      <a href="#" class="navbar__logo" aria-label="Benbia - Inicio">BENB<span class="logo-highlight">IA</span></a>
      <span class="navbar__tagline">Pensado. Creado. Tuyo.</span>
    </div>
    <div class="navbar__links">
      <a href="#servicios" class="nav-link">Servicios</a>
      <a href="#proceso" class="nav-link">Proceso</a>
      <a href="#contacto" class="btn-primary navbar__cta">Hablemos</a>
    </div>
    <button class="navbar__mobile-toggle" id="mobile-toggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
  <!-- Mobile menu -->
  <div class="navbar__mobile-menu" id="mobile-menu">
    <a href="#servicios" class="nav-link">Servicios</a>
    <a href="#proceso" class="nav-link">Proceso</a>
    <a href="#contacto" class="btn-primary" style="margin-top: 1rem; text-align: center;">Hablemos</a>
  </div>
</nav>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 80) {
      navbar?.classList.add('navbar--scrolled');
    } else {
      navbar?.classList.remove('navbar--scrolled');
    }
    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 0;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar--scrolled {
    background-color: rgba(8, 76, 97, 0.4);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .navbar__inner {
    padding-inline: var(--container-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar__brand {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .navbar__tagline {
    font-size: 0.75rem;
    color: var(--muted-teal);
    opacity: 0.5;
    font-weight: 300;
  }

  .navbar__logo {
    font-family: 'Syne Variable', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    background: linear-gradient(90deg, var(--canary-yellow) 50%, var(--heading-light) 50%);
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background-position 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .navbar__logo:hover {
    background-position: 0% 0;
  }

  .navbar__logo :global(.logo-highlight) {
    background: linear-gradient(90deg, var(--heading-light) 50%, var(--canary-yellow) 50%);
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-left: -0.03em;
    transition: background-position 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .navbar__logo:hover :global(.logo-highlight) {
    background-position: 0% 0;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .navbar__links .nav-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted-teal);
    transition: color 0.4s ease;
  }

  .navbar__links .nav-link:hover {
    color: var(--heading-light);
  }

  .navbar__cta {
    padding: 0.55rem 1.25rem;
    font-size: 0.8rem;
  }

  .navbar__mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 4px;
  }

  .navbar__mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--heading-light);
    transition: all 0.4s ease;
    transform-origin: center;
  }

  .navbar__mobile-toggle.is-open span:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .navbar__mobile-toggle.is-open span:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  .navbar__mobile-menu {
    display: flex;
    flex-direction: column;
    padding: 0 var(--container-padding);
    gap: 0;
    background-color: rgba(8, 76, 97, 0.6);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    max-height: 0;
    overflow: hidden;
    transition:
      max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      padding 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .navbar__mobile-menu.is-open {
    max-height: 320px;
    padding: 1.5rem var(--container-padding);
    gap: 1.25rem;
  }

  .navbar__mobile-menu .nav-link {
    font-size: 1.1rem;
    color: var(--muted-teal);
    padding: 0.5rem 0;
    opacity: 0;
    transform: translateX(-10px);
    transition:
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s ease;
  }

  .navbar__mobile-menu.is-open .nav-link {
    opacity: 1;
    transform: translateX(0);
  }

  .navbar__mobile-menu.is-open .nav-link:nth-child(1) { transition-delay: 0.05s; }
  .navbar__mobile-menu.is-open .nav-link:nth-child(2) { transition-delay: 0.1s; }
  .navbar__mobile-menu.is-open .nav-link:nth-child(3) { transition-delay: 0.15s; }

  .navbar__mobile-menu .btn-primary {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .navbar__mobile-menu.is-open .btn-primary {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.2s;
  }

  @media (max-width: 768px) {
    .navbar__links {
      display: none;
    }

    .navbar__mobile-toggle {
      display: flex;
    }

    .navbar__tagline {
      display: none;
    }

    .navbar__mobile-menu {
      position: fixed;
      inset: 0;
      height: 100dvh;
      max-height: none;
      background-color: rgba(8, 76, 97, 0.95);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      justify-content: center;
      align-items: center;
      text-align: center;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 90;
    }

    .navbar__mobile-menu.is-open {
      max-height: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      padding: 0;
      gap: 0.5rem;
    }

    .navbar__mobile-menu .nav-link {
      font-size: 1.5rem;
      padding: 1rem 0;
      font-weight: 500;
      color: var(--heading-light);
    }

    .navbar__mobile-menu .btn-primary {
      margin-top: 1.5rem;
      padding: 1rem 2.5rem;
      font-size: 1rem;
    }

    .navbar__mobile-toggle {
      z-index: 101;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 1rem 0;
    }

    .navbar--scrolled {
      padding: 0.5rem 0;
    }

    .navbar__logo {
      font-size: 1.2rem;
    }

    .navbar__mobile-menu .nav-link {
      font-size: 1.3rem;
      padding: 0.85rem 0;
    }
  }
</style>
