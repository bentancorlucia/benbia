---
---

<nav class="navbar" id="navbar">
  <div class="navbar__pill">
    <a href="#" class="navbar__logo" aria-label="Benbia - Inicio">
      <span class="navbar__brand">BENB<span class="logo-ia">IA</span></span>
    </a>

    <div class="navbar__links">
      <a href="#servicios" class="nav-link">Servicios</a>
      <a href="#proceso" class="nav-link">Proceso</a>
      <a href="#trabajos" class="nav-link">Portfolio</a>
    </div>

    <a href="#contacto" class="btn-primary navbar__cta">
      Hablemos
    </a>

    <button class="navbar__mobile-toggle" id="mobile-toggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile-menu" id="mobile-menu">
    <a href="#servicios" class="mobile-nav-link">Servicios</a>
    <a href="#proceso" class="mobile-nav-link">Proceso</a>
    <a href="#trabajos" class="mobile-nav-link">Portfolio</a>
    <a href="#contacto" class="btn-primary navbar__mobile-cta">Hablemos</a>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      navbar?.classList.add('navbar--scrolled');
    } else {
      navbar?.classList.remove('navbar--scrolled');
    }
  });

  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.5rem var(--container-padding);
    display: flex;
    justify-content: center;
    transition: padding 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar--scrolled {
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .navbar__pill {
    width: 100%;
    max-width: 960px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.75rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: 100px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    transition: box-shadow 0.4s ease, background 0.4s ease;
  }

  .navbar--scrolled .navbar__pill {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    background: rgba(255, 255, 255, 0.06);
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .navbar__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--canary-yellow);
    box-shadow: 0 0 8px var(--canary-yellow);
    animation: dot-pulse 3s ease-in-out infinite;
  }

  .navbar__brand {
    font-family: 'Syne Variable', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    color: var(--heading-light);
  }

  .navbar__brand :global(.logo-ia) {
    color: var(--canary-yellow);
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .navbar__links .nav-link {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.3s ease;
  }

  .navbar__cta {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
  }

  .navbar__mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 4px;
  }

  .navbar__mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--heading-light);
    transition: all 0.4s ease;
    transform-origin: center;
  }

  .navbar__mobile-toggle.is-open span:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .navbar__mobile-toggle.is-open span:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* Mobile menu - fullscreen overlay */
  .navbar__mobile-menu {
    display: none;
  }

  .mobile-nav-link {
    font-family: 'Syne Variable', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--heading-light);
    transition: color 0.3s ease;
  }

  .mobile-nav-link:hover {
    color: var(--canary-yellow);
  }

  .navbar__mobile-cta {
    margin-top: 1.5rem;
    font-size: 1rem;
    padding: 1rem 2.5rem;
  }

  @media (max-width: 768px) {
    .navbar__links,
    .navbar__cta {
      display: none;
    }

    .navbar__mobile-toggle {
      display: flex;
    }

    .navbar__mobile-menu {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 1.25rem;
      position: fixed;
      inset: 0;
      height: 100dvh;
      background-color: rgba(5, 49, 64, 0.95);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.4s ease, visibility 0.4s ease;
      z-index: 90;
    }

    .navbar__mobile-menu.is-open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .navbar__mobile-menu .mobile-nav-link {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .navbar__mobile-menu.is-open .mobile-nav-link {
      opacity: 1;
      transform: translateY(0);
    }

    .navbar__mobile-menu.is-open .mobile-nav-link:nth-child(1) { transition-delay: 0.05s; }
    .navbar__mobile-menu.is-open .mobile-nav-link:nth-child(2) { transition-delay: 0.1s; }
    .navbar__mobile-menu.is-open .mobile-nav-link:nth-child(3) { transition-delay: 0.15s; }
    .navbar__mobile-menu.is-open .navbar__mobile-cta { transition-delay: 0.2s; }

    .navbar__mobile-toggle {
      z-index: 101;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 1rem var(--container-padding);
    }

    .navbar--scrolled {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }

    .navbar__pill {
      padding: 0.65rem 1.25rem;
    }

    .navbar__brand {
      font-size: 1.05rem;
    }
  }
</style>
