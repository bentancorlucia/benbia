---
const steps = [
  {
    num: '01',
    title: 'Descubrimiento',
    desc: 'Entendemos tu negocio a nivel estructural, perfilamos a tus usuarios y definimos objetivos claros.',
    accent: 'var(--canary-yellow)',
  },
  {
    num: '02',
    title: 'Diseño',
    desc: 'Prototipamos soluciones de alta fidelidad, con foco absoluto en la experiencia y estética visual.',
    accent: 'var(--berry-crush)',
  },
  {
    num: '03',
    title: 'Desarrollo',
    desc: 'Construimos la arquitectura con tecnología moderna, código limpio y entregas iterativas ágiles.',
    accent: 'var(--muted-teal)',
  },
  {
    num: '04',
    title: 'Lanzamiento',
    desc: 'Desplegamos en entornos seguros, monitoreamos métricas en vivo y optimizamos post-lanzamiento.',
    accent: 'var(--heading-light)',
  },
];
---

<section class="process section--railed" id="proceso">
  <div class="process__inner">
    <!-- Header -->
    <div class="process__header">
      <div class="process__header-left">
        <span class="label process__label">[ Metodología ]</span>
        <h2 class="process__title">
          <span class="process__title-line">Nuestro</span>
          <span class="process__title-line"><em>proceso.</em></span>
        </h2>
      </div>
      <p class="process__header-desc">
        Un ciclo iterativo diseñado para reducir fricción, maximizar calidad y asegurar el impacto comercial.
      </p>
    </div>

    <!-- Background text -->
    <div class="process__bg-text" aria-hidden="true">FLOW</div>

    <!-- Timeline -->
    <div class="process__timeline">
      <svg class="process__path" aria-hidden="true">
        <path class="process__path-line" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="6 5" />
      </svg>

      <div class="process__steps">
        {
          steps.map((step, i) => (
            <div
              class={`process__step ${i % 2 !== 0 ? 'process__step--offset' : ''}`}
              data-step-index={i}
              style={`--step-accent: ${step.accent};`}
            >
              <div class="process__node" aria-hidden="true">
                <div class="process__node-dot"></div>
              </div>
              <div class="process__step-content">
                <span class="process__step-num">{step.num}</span>
                <h3 class="process__step-title">{step.title}</h3>
                <p class="process__step-desc">{step.desc}</p>
              </div>
              <div class="process__step-line" aria-hidden="true"></div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .process {
    position: relative;
    padding-block: var(--space-2xl);
    overflow: hidden;
  }

  .process__inner {
    padding-inline: var(--container-padding);
    position: relative;
  }

  /* Background decorative text */
  .process__bg-text {
    position: absolute;
    right: -5%;
    top: 0;
    font-family: 'Syne Variable', sans-serif;
    font-weight: 800;
    font-size: clamp(8rem, 20vw, 18rem);
    line-height: 1;
    color: rgba(255, 255, 255, 0.02);
    pointer-events: none;
    user-select: none;
  }

  /* Header */
  .process__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(4rem, 10vw, 8rem);
    position: relative;
    z-index: 2;
  }

  .process__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(12px);
  }

  .process__label::before {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--berry-crush);
  }

  .process__title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .process__title-line {
    display: block;
    opacity: 0;
    transform: translateY(20px);
  }

  .process__title em {
    font-style: italic;
    color: var(--canary-yellow);
    font-weight: 400;
    font-family: 'Outfit Variable', sans-serif;
  }

  .process__header-desc {
    max-width: 340px;
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    line-height: 1.7;
    color: var(--muted-teal);
    font-weight: 350;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    padding-left: 1.5rem;
    padding-block: 0.5rem;
    opacity: 0;
    transform: translateY(12px);
  }

  /* Timeline container */
  .process__timeline {
    position: relative;
  }

  /* SVG path connecting dots */
  .process__path {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  /* Steps grid */
  .process__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 2rem);
    padding-top: 2rem;
  }

  /* Each step */
  .process__step {
    position: relative;
    z-index: 2;
    opacity: 0;
    transform: translateY(30px);
  }

  .process__step--offset {
    margin-top: 3rem;
  }

  /* Node dot on the horizon line */
  .process__node {
    position: absolute;
    top: -2rem;
    left: 0;
    transform: translateY(-50%);
    z-index: 3;
  }

  .process__node-dot {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: var(--muted-teal);
    border: 2px solid var(--dark-teal);
    transition: background 0.3s ease,
                transform 0.3s ease,
                box-shadow 0.3s ease;
  }

  .process__step:hover .process__node-dot {
    background: var(--canary-yellow);
    transform: scale(1.3);
    box-shadow: 0 0 20px rgba(237, 240, 96, 0.4);
  }

  /* Step content */
  .process__step-content {
    position: relative;
  }

  .process__step-num {
    display: block;
    font-family: 'Syne Variable', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 6vw, 4.5rem);
    line-height: 1;
    -webkit-text-stroke: 1.5px rgba(237, 240, 96, 0.25);
    color: transparent;
    margin-bottom: 1.5rem;
    transition: -webkit-text-stroke 0.4s ease,
                color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s ease;
  }

  .process__step:hover .process__step-num {
    -webkit-text-stroke: 0px transparent;
    color: var(--canary-yellow);
    transform: translateX(8px);
  }

  .process__step-title {
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: 700;
    color: var(--heading-light);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    transition: color 0.4s ease;
  }

  .process__step:hover .process__step-title {
    color: var(--canary-yellow);
  }

  .process__step-desc {
    font-size: clamp(0.9rem, 1.1vw, 1rem);
    line-height: 1.7;
    color: var(--muted-teal);
    font-weight: 350;
  }

  /* Mobile vertical line accent */
  .process__step-line {
    display: none;
  }

  /* Responsive: Tablet */
  @media (max-width: 1024px) {
    .process__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }

    .process__step--offset {
      margin-top: 0;
    }

    .process__path {
      display: none;
    }

    .process__node {
      display: none;
    }

    .process__step-line {
      display: block;
      position: absolute;
      top: 0;
      left: -1px;
      width: 2px;
      height: 0;
      background: var(--canary-yellow);
      transition: height 0.7s ease-out;
      z-index: 1;
    }

    .process__step {
      padding-left: 1.5rem;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .process__step:hover .process__step-line {
      height: 100%;
    }
  }

  /* Responsive: Mobile */
  @media (max-width: 768px) {
    .process {
      border: none;
    }

    .process__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .process__header-desc {
      border-left: none;
      padding-left: 0;
      max-width: 100%;
    }

    .process__title {
      font-size: clamp(2.2rem, 8.5vw, 3.5rem);
    }

    .process__steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .process__bg-text {
      font-size: 6rem;
      right: -10%;
    }
  }

  @media (max-width: 480px) {
    .process__step-num {
      font-size: 3rem;
    }

    .process__step-title {
      font-size: 1.2rem;
    }

    .process__step-desc {
      font-size: 0.85rem;
      line-height: 1.6;
    }

    .process__bg-text {
      display: none;
    }
  }
</style>

<script>
  function drawProcessPath() {
    const timeline = document.querySelector<HTMLElement>('.process__timeline');
    const stepsContainer = document.querySelector<HTMLElement>('.process__steps');
    const pathLine = document.querySelector('.process__path-line');
    const steps = document.querySelectorAll<HTMLElement>('.process__step');

    if (!timeline || !stepsContainer || !pathLine || steps.length < 2) return;
    if (window.innerWidth <= 1024) return;

    const timelineRect = timeline.getBoundingClientRect();
    const points: { x: number; y: number }[] = [];

    steps.forEach((step) => {
      const dot = step.querySelector<HTMLElement>('.process__node-dot');
      if (!dot) return;

      // Use getBoundingClientRect for accurate visual positions,
      // but compensate for GSAP transforms on the step
      const matrix = new DOMMatrix(getComputedStyle(step).transform);
      const dotRect = dot.getBoundingClientRect();

      points.push({
        x: dotRect.left + dotRect.width / 2 - timelineRect.left - matrix.e,
        y: dotRect.top + dotRect.height / 2 - timelineRect.top - matrix.f,
      });
    });

    if (points.length < 2) return;

    // Add an extra point past the last dot, curving back to the Y of the first dot
    const last = points[points.length - 1];
    const first = points[0];
    const extraX = timelineRect.width;
    points.push({ x: extraX, y: first.y });

    // Build a smooth cubic bezier path through all points
    let d = `M ${points[0].x} ${points[0].y}`;
    for (let i = 0; i < points.length - 1; i++) {
      const curr = points[i];
      const next = points[i + 1];
      const midX = (curr.x + next.x) / 2;
      d += ` C ${midX} ${curr.y}, ${midX} ${next.y}, ${next.x} ${next.y}`;
    }

    pathLine.setAttribute('d', d);
  }

  // Draw immediately and on resize
  drawProcessPath();
  window.addEventListener('load', drawProcessPath);
  window.addEventListener('resize', drawProcessPath);

  // Redraw when the timeline is observed to handle layout shifts
  const timeline = document.querySelector('.process__timeline');
  if (timeline) {
    new ResizeObserver(drawProcessPath).observe(timeline);
  }
</script>
