---

<section class="hero" id="hero">
  <div class="hero__content">
    <h1 class="hero__title">
      <span class="hero__line">Construimos</span>
      <span class="hero__line">el software <em>que</em>&nbsp;</span>
      <span class="hero__line">tu negocio</span>
      <span class="hero__line"><span class="hero__accent">necesita</span></span>
    </h1>
    <p class="hero__subtitle">
      Desarrollo, diseño y consultoría tecnológica para empresas que piensan diferente.
    </p>
    <a href="#servicios" class="btn-primary hero__cta">
      Conoce nuestros servicios
      <span class="arrow">&rarr;</span>
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-text">Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: visible;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    padding-inline: var(--container-padding);
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: visible;
  }

  .hero__title {
    margin-bottom: clamp(1rem, 2.5vw, 1.5rem);
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .hero__line {
    display: block;
    opacity: 0;
    clip-path: inset(100% 0 0 0);
    padding-block: 0.1em;
  }

  .hero__title em {
    font-style: italic;
    color: var(--muted-teal);
    font-weight: 500;
  }

  .hero__accent {
    background: linear-gradient(
      90deg,
      var(--canary-yellow) 0%,
      #f5f872 40%,
      var(--canary-yellow) 60%,
      #f5f872 100%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 6s ease-in-out infinite;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 1.2vw + 0.2rem, 1.25rem);
    font-weight: 300;
    max-width: 550px;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.7;
    opacity: 0;
  }

  .hero__cta {
    opacity: 0;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
  }

  .hero__scroll-text {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--muted-teal);
    opacity: 0.5;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--muted-teal-20), transparent);
    animation: scroll-bounce 2.5s ease-in-out infinite;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding-top: 6rem;
      padding-bottom: 3rem;
      min-height: 85svh;
    }

    .hero__title {
      font-size: clamp(1.8rem, 6vw, 3rem);
    }

    .hero__subtitle {
      max-width: 100%;
    }

    .hero__scroll {
      bottom: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 5rem;
      padding-bottom: 3rem;
      min-height: 85svh;
    }

    .hero__title {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .hero__subtitle {
      font-size: 0.9rem;
      margin-bottom: var(--space-md);
      line-height: 1.5;
    }

    .hero__scroll {
      display: none;
    }
  }

  @media (max-width: 360px) {
    .hero__title {
      font-size: 1.4rem;
    }

    .hero__subtitle {
      font-size: 0.85rem;
    }

    .hero__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
