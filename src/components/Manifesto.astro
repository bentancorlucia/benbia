---
const words = 'No construimos software genérico. Diseñamos soluciones que transforman negocios.'.split(' ');
---

<section class="manifesto" id="manifiesto">
  <!-- Dot matrix background -->
  <div class="manifesto__dots" aria-hidden="true"></div>

  <div class="container manifesto__inner">
    <p class="manifesto__text" id="manifesto-text">
      {words.map((word) => (
        <span class="manifesto__word">{word}&nbsp;</span>
      ))}
    </p>
  </div>
</section>

<style>
  .manifesto {
    position: relative;
    height: 100vh;
    background-color: var(--dark-teal-deep);
    overflow: hidden;
  }

  .manifesto__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(237, 240, 96, 0.08) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .manifesto__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .manifesto__text {
    font-family: 'Syne Variable', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.2;
    color: var(--heading-light);
    text-align: center;
    max-width: 900px;
  }

  .manifesto__word {
    display: inline-block;
    opacity: 0.12;
    transition:
      opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.4s ease;
    filter: blur(1px);
  }

  @media (max-width: 768px) {
    .manifesto__text {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {

    .manifesto__text {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    .manifesto__dots {
      background-size: 18px 18px;
    }
  }
</style>
