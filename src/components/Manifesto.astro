---

<section class="manifesto" id="manifiesto">
  <!-- Mesh gradient background -->
  <div class="manifesto__gradient" aria-hidden="true">
    <div class="manifesto__blob manifesto__blob--1"></div>
    <div class="manifesto__blob manifesto__blob--2"></div>
    <div class="manifesto__blob manifesto__blob--3"></div>
    <div class="manifesto__blob manifesto__blob--4"></div>
  </div>

  <!-- Noise texture overlay -->
  <div class="manifesto__noise" aria-hidden="true"></div>

  <div class="container manifesto__inner">
    <p class="manifesto__text">
      <span class="manifesto__word">No construimos software genérico.</span> <span class="manifesto__word">Diseñamos soluciones que</span> <span class="manifesto__word manifesto__word--accent"><em>transforman negocios.</em></span>
    </p>
  </div>
</section>

<style>
  .manifesto {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background-color: var(--dark-teal);
  }

  /* Mesh gradient */
  .manifesto__gradient {
    position: absolute;
    inset: 0;
  }

  .manifesto__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    will-change: transform;
  }

  .manifesto__blob--1 {
    width: 60%;
    height: 60%;
    top: -15%;
    left: -10%;
    background: radial-gradient(circle, var(--berry-crush) 0%, transparent 70%);
    opacity: 0.3;
  }

  .manifesto__blob--2 {
    width: 50%;
    height: 50%;
    top: 10%;
    right: -5%;
    background: radial-gradient(circle, var(--dark-teal) 0%, transparent 70%);
    opacity: 0.4;
  }

  .manifesto__blob--3 {
    width: 60%;
    height: 60%;
    bottom: -10%;
    left: 10%;
    background: radial-gradient(circle, var(--canary-yellow) 0%, transparent 70%);
    opacity: 0.15;
  }

  .manifesto__blob--4 {
    width: 50%;
    height: 50%;
    bottom: 5%;
    right: -5%;
    background: radial-gradient(circle, var(--muted-teal) 0%, transparent 70%);
    opacity: 0.2;
  }

  /* Noise overlay for texture */
  .manifesto__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.15'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    pointer-events: none;
    opacity: 0.4;
    mix-blend-mode: overlay;
  }

  .manifesto__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
  }

  .manifesto__text {
    font-family: 'Syne Variable', sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 4rem);
    line-height: 1.25;
    color: var(--heading-light);
    max-width: 1000px;
    letter-spacing: -0.02em;
  }

  .manifesto__text em {
    font-style: italic;
    font-weight: 400;
    font-family: 'Outfit Variable', sans-serif;
  }

  .manifesto__word {
    display: inline;
    opacity: 0;
    transform: translateY(16px);
  }

  .manifesto__word--accent {
    color: var(--canary-yellow);
  }

  /* ── Tablet / Large mobile ── */
  @media (max-width: 768px) {
    .manifesto {
      height: 100svh;
    }

    .manifesto__inner {
      padding-inline: 1.5rem;
      /* Shift optical center slightly up */
      align-items: center;
      justify-content: center;
    }

    .manifesto__text {
      font-size: clamp(1.8rem, 7.5vw, 3rem);
      line-height: 1.15;
      letter-spacing: -0.03em;
      text-align: center;
      max-width: 100%;
    }

    .manifesto__text em {
      /* Make the italic accent phrase pop on mobile */
      font-size: 1.05em;
    }

    /* Blobs: scale up but reduce blur for performance */
    .manifesto__blob {
      filter: blur(70px);
    }

    .manifesto__blob--1 {
      width: 90vw;
      height: 90vw;
      top: -10%;
      left: -20%;
      opacity: 0.35;
    }

    .manifesto__blob--2 {
      width: 70vw;
      height: 70vw;
      top: 15%;
      right: -15%;
      opacity: 0.45;
    }

    .manifesto__blob--3 {
      width: 80vw;
      height: 80vw;
      bottom: -5%;
      left: 0%;
      opacity: 0.18;
    }

    .manifesto__blob--4 {
      width: 70vw;
      height: 70vw;
      bottom: 10%;
      right: -10%;
      opacity: 0.22;
    }
  }

  /* ── Small mobile ── */
  @media (max-width: 480px) {
    .manifesto__inner {
      padding-inline: 1.25rem;
    }

    .manifesto__text {
      font-size: clamp(1.5rem, 7vw, 2.2rem);
      line-height: 1.2;
      letter-spacing: -0.025em;
    }

    .manifesto__blob {
      filter: blur(50px);
    }

    .manifesto__blob--3,
    .manifesto__blob--4 {
      display: none;
    }
  }

  /* ── Tiny screens ── */
  @media (max-width: 360px) {
    .manifesto__text {
      font-size: 1.4rem;
      line-height: 1.25;
    }
  }
</style>
